# Kopieren nach .env und bei Bedarf anpassen — .env wird nicht committet.

# Port, unter dem die Web-App lokal erreichbar ist
WEB_PORT=8081

# PostgreSQL-Verbindung (lokales Docker-Compose-Setup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cockpit
DB_USER=cockpit
DB_PASSWORD=cockpit

# Backend
BACKEND_PORT=8085
JWT_SECRET=change-me-in-local-env
