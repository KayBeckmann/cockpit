# Kopieren nach .env und bei Bedarf anpassen — .env wird nicht committet.

# Port, unter dem die Web-App lokal erreichbar ist
WEB_PORT=8081

# PostgreSQL-Verbindung — DB_HOST=localhost gilt für Tools, die außerhalb
# von Docker laufen (z.B. `dart_frog dev`, `dart run bin/migrate.dart`)
# und über den gemappten Port zugreifen. Der "backend"-Service im
# Compose-Stack überschreibt DB_HOST/DB_PORT auf "db"/5432, da er die
# Datenbank über das interne Docker-Netzwerk erreicht.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cockpit
DB_USER=cockpit
DB_PASSWORD=cockpit

# Backend
BACKEND_PORT=8085
JWT_SECRET=change-me-in-local-env
